{
  "productName": "OmniNova Claw",
  "version": "0.1.0",
  "identifier": "com.omninova.claw",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OmniNova Claw",
        "width": 1080,
        "height": 720,
        "minWidth": 860,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/agent-browser/macos",
      "resources/agent-browser/linux",
      "resources/agent-browser/windows",
      "resources/cli"
    ],
    "macOS": {
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "10.15"
    }
  }
}
